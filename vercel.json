{
  "buildCommand": "bash scripts/build-web.sh",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/admin-teams", "destination": "/admin-teams.html" },
    { "source": "/admin/login", "destination": "/admin/login.html" },
    { "source": "/admin", "destination": "/admin/index.html" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/app/:path*", "destination": "/app.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/reset-password", "destination": "/app.html" },
    { "source": "/verify-email", "destination": "/app.html" },
    { "source": "/forgot-password", "destination": "/app.html" },
    { "source": "/login", "destination": "/app.html" },
    { "source": "/register", "destination": "/app.html" }
  ]
}
